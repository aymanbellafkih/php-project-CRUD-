
{% extends 'base.html.twig' %}

{% block title %}Liste des terrains{% endblock %}

{% block page_title %}🏟️ Liste des terrains sportifs{% endblock %}

{% block body %}
    <div class=\"container mt-4\">
        <div class=\"d-flex justify-content-between align-items-center mb-4\">
            <h1>Liste des terrains</h1>
            <a href="{{ path('app_terrain_new') }}" class=\"btn btn-success\">
                <i class=\"bi bi-plus-circle\"></i> Nouveau terrain
            </a>
             href="{{ path('app_terrain_commentaires') }}" class=\"btn btn-success\">
                <i class=\"bi bi-plus-circle\"></i> commentaires
            </a>
        </div>

        {% if terrains is empty %}
            <div class=\"alert alert-info\">
                Aucun terrain trouvé dans la base de données.
                <a href="{{ path('app_terrain_new') }}" class=\"alert-link\">Ajoutez le premier terrain !</a>
            </div>
        {% else %}
            <div class=\"table-responsive\">
                <table class=\"table table-striped table-hover\">
                    <thead class=\"table-dark\">
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Sport</th>
                            <th>Disponible</th>
                            <th>Date réservation</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for terrain in terrains %}
                        <tr>
                            <td>{{ terrain.id }}</td>
                            <td>{{ terrain.nom }}</td>
                            <td>
                                <span class=\"badge bg-primary\">{{ terrain.typeSport }}</span>
                            </td>
                            <td>
                                {% if terrain.disponibilite %}
                                    <span class=\"badge bg-success\">✅ Oui</span>
                                {% else %}
                                    <span class=\"badge bg-danger\">❌ Non</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if terrain.dateReservation %}
                                    {{ terrain.dateReservation|date('d/m/Y H:i') }}
                                {% else %}
                                    <span class=\"text-muted\">Non réservé</span>
                                {% endif %}
                            </td>
                            <td>
                              <div class="btn-group" role="group">
    <a href="{{ path('app_terrain_show', {'id': terrain.id}) }}" class="btn btn-info btn-sm">
        👁️ Voir
    </a>
    <a href="{{ path('app_terrain_edit', {'id': terrain.id}) }}" class="btn btn-warning btn-sm">
        ✏️ Modifier
    </a>
</div>

                                   <form method="post"
      action="{{ path('app_terrain_delete', {'id': terrain.id}) }}"
      class="d-inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ terrain.id) }}">
    <button class="btn btn-danger btn-sm"
            onclick="return confirm('Supprimer ce terrain ?')">
        🗑️ Supprimer
    </button>
</form>

                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
{% endblock %}
