{% extends "base.html.twig" %}
{% block title %}Page de commentaires{% endblock %}

{% block body %}
    <h1>commentaires</h1>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
            {% for commentaires in contacts %}
                <tr>
                    <td>{{ commentaires.nom }}</td>
                    <td>{{ commentaires.message }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="2">Aucun commentaire trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}