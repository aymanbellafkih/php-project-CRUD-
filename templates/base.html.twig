<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}🏟️ Gestion des Terrains Sportifs{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        
        {# Bootstrap 5 CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
        
        {# Bootstrap Icons #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
        
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body>
        {# Navigation Bar #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_terrain_index') }}">
                    <i class="bi bi-tree-fill"></i> Terrains Sportifs
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_terrain_index' ? 'active' : '' }}" 
                               href="{{ path('app_terrain_index') }}">
                                <i class="bi bi-list-ul"></i> Liste des terrains
                            </a>
                            <a class="nav-link {{ app.request.get('_route') == 'app_terrain_commentaires' ? 'active' : '' }}" 
                               href="{{ path('app_terrain_commentaires') }}">
                                <i class="bi bi-plus-circle"></i> commentaires
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_terrain_new' ? 'active' : '' }}" 
                               href="{{ path('app_terrain_new') }}">
                                <i class="bi bi-plus-circle"></i> Nouveau terrain
                            </a>
                            
                        </ul>
                    
                    <div class="navbar-text">
                        <span class="badge bg-info">
                            <i class="bi bi-database"></i> Symfony 6
                        </span>
                    </div>
                </div>
            </div>
        </nav>

        {# Main Content #}
        <main class="container my-4">
            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            
            {# Page Title #}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="display-6">
                    {% block page_title %}{% endblock %}
                </h1>
                {% block actions %}{% endblock %}
            </div>
            
            {# Page Content #}
            {% block body %}{% endblock %}
        </main>

        {# Footer #}
        <footer class="bg-dark text-white py-4 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h5><i class="bi bi-info-circle"></i> Application Terrains Sportifs</h5>
                        <p class="mb-0">
                            Gestion des réservations de terrains sportifs<br>
                            Développé avec Symfony 6
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <h5><i class="bi bi-link"></i> Liens rapides</h5>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_terrain_index') }}" class="text-white-50 text-decoration-none">Liste des terrains</a></li>
                            <li><a href="{{ path('app_terrain_new') }}" class="text-white-50 text-decoration-none">Ajouter un terrain</a></li>
                        </ul>
                    </div>
                </div>
                <hr class="bg-secondary">
                <div class="text-center">
                    <p class="mb-0">
                        &copy; {{ "now"|date("Y") }} - Application Terrains Sportifs
                        <span class="mx-2">•</span>
                        <span class="text-muted">PHP {{ constant('PHP_VERSION') }}</span>
                    </p>
                </div>
            </div>
        </footer>

        {# Bootstrap 5 JS #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
        
        {# Custom JS #}
        <script>
            // Activer les tooltips Bootstrap
            document.addEventListener('DOMContentLoaded', function() {
                var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl);
                });
                
                // Auto-dismiss alerts after 5 seconds
                setTimeout(function() {
                    var alerts = document.querySelectorAll('.alert');
                    alerts.forEach(function(alert) {
                        var bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    });
                }, 5000);
            });
        </script>
        
        {% block scripts %}{% endblock %}
    </body>
</html>